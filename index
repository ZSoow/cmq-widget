async function loadAll() {
  try {
    const [actions, projets, wps, actionsProjet, membres] = await Promise.all([
      grist.docApi.fetchTable('SAISIE_actions_realisees'),
      grist.docApi.fetchTable('PROJET_projet'),
      grist.docApi.fetchTable('PROJET_axes'),
      grist.docApi.fetchTable('PROJET_Actions'),
      grist.docApi.fetchTable('CMQ_RH'),
    ]);

    function tableToRows(t) {
      const keys = Object.keys(t);
      const len = t[keys[0]]?.length || 0;
      return Array.from({length: len}, (_, i) => {
        const row = {};
        keys.forEach(k => row[k] = t[k][i]);
        return row;
      });
    }

    gristData.actions = tableToRows(actions);
    gristData.projets = tableToRows(projets);
    gristData.wps = tableToRows(wps);
    gristData.actionsProjet = tableToRows(actionsProjet);
    gristData.membres = tableToRows(membres);

    renderKPIs();
    renderRecent();
    renderResps();
    populateFormSelects();

  } catch(e) {
    console.warn('Mode démo (hors Grist) :', e.message);
    loadDemoData();
  }
}

